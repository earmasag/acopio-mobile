{
  "architecture_version": "3.0",
  "global_settings": {
    "default_timeout_seconds": 12.0,
    "retry_policy": {
      "max_retries": 2,
      "backoff_factor": 1.5
    }
  },
  "apis": {
    "open_food_facts": {
      "base_url": "https://world.openfoodfacts.org/api/v3/product/{barcode}.json",
      "method": "GET",
      "headers": {
        "User-Agent": "BuscadorCodigoBarras/1.0 (soporte@buscadorbarras.com)"
      },
      "routing_rules": {
        "allowed_categories": ["food", "beverage"],
        "excluded_prefixes": ["978", "979"]
      },
      "optimization": {
        "use_fields_filter": true,
        "fields": ["product_name", "brands", "image_url", "ingredients_text", "nutriments", "nutriscore_grade"]
      }
    },
    "open_beauty_facts": {
      "base_url": "https://world.openbeautyfacts.org/api/v2/product/{barcode}.json",
      "method": "GET",
      "headers": {
        "User-Agent": "BuscadorCodigoBarras/1.0 (soporte@buscadorbarras.com)"
      },
      "routing_rules": {
        "allowed_categories": ["cosmetics", "personal_care"],
        "excluded_prefixes": ["978", "979"]
      },
      "optimization": {
        "use_fields_filter": false
      }
    },
    "open_pet_food_facts": {
      "base_url": "https://world.openpetfoodfacts.org/api/v2/product/{barcode}.json",
      "method": "GET",
      "headers": {
        "User-Agent": "BuscadorCodigoBarras/1.0 (soporte@buscadorbarras.com)"
      },
      "routing_rules": {
        "allowed_categories": ["pet_food", "pet_care"],
        "excluded_prefixes": ["978", "979"]
      },
      "optimization": {
        "use_fields_filter": false
      }
    },
    "open_products_facts": {
      "base_url": "https://world.openproductsfacts.org/api/v3/product/{barcode}.json",
      "method": "GET",
      "headers": {
        "User-Agent": "BuscadorCodigoBarras/1.0 (soporte@buscadorbarras.com)"
      },
      "routing_rules": {
        "allowed_categories": ["ropa", "juguetes", "insumos_medicos"],
        "excluded_prefixes": ["978", "979"]
      },
      "optimization": {
        "use_fields_filter": true,
        "fields": ["product_name", "brands", "categories", "image_url"]
      }
    },
    "upcitemdb_trial": {
      "base_url": "https://api.upcitemdb.com/prod/trial/lookup?upc={barcode}",
      "method": "GET",
      "headers": {
        "Accept": "application/json"
      },
      "routing_rules": {
        "allowed_categories": ["all"],
        "execution_policy": "client_side_only"
      },
      "rate_limiting": {
        "max_requests_per_day_per_ip": 100,
        "burst_limit_seconds": 30,
        "max_burst_requests": 15
      }
    },
    "open_library": {
      "base_url": "https://openlibrary.org/api/books?bibkeys=ISBN:{barcode}&format=json&jscmd=data",
      "method": "GET",
      "headers": {
        "Accept": "application/json"
      },
      "routing_rules": {
        "required_prefixes": ["978", "979"],
        "allowed_categories": ["books"]
      }
    },
    "access_gudid": {
      "base_url": "https://accessgudid.nlm.nih.gov/api/v2/devices/lookup.json?di={barcode}",
      "method": "GET",
      "headers": {
        "Accept": "application/json"
      },
      "routing_rules": {
        "allowed_categories": ["insumos_medicos"],
        "excluded_prefixes": ["978", "979"]
      }
    },
    "openfda_drugs": {
      "base_url": "https://api.fda.gov/drug/ndc.json?api_key=3WhFZ4zLAx1tgRYrnzHcpqtLvPKDVls4ePqQfLIn&search={barcode}",
      "method": "GET",
      "headers": {
        "Accept": "application/json"
      },
      "routing_rules": {
        "allowed_categories": ["medicamentos"],
        "excluded_prefixes": ["978", "979"]
      }
    },
    "openfda_devices": {
      "base_url": "https://api.fda.gov/device/udi.json?api_key=3WhFZ4zLAx1tgRYrnzHcpqtLvPKDVls4ePqQfLIn&search={barcode}",
      "method": "GET",
      "headers": {
        "Accept": "application/json"
      },
      "routing_rules": {
        "allowed_categories": ["insumos_medicos"],
        "excluded_prefixes": ["978", "979"]
      }
    },
    "cima_medicamentos": {
      "base_url": "https://cima.aemps.es/cima/rest/medicamentos?cn={barcode}",
      "method": "GET",
      "headers": {
        "Accept": "application/json"
      },
      "routing_rules": {
        "allowed_categories": ["medicamentos"],
        "excluded_prefixes": ["978", "979"]
      }
    },
    "brocade": {
      "base_url": "https://www.brocade.io/api/items/{barcode}",
      "method": "GET",
      "headers": {
        "Accept": "application/json"
      },
      "routing_rules": {
        "allowed_categories": ["all"],
        "excluded_prefixes": ["978", "979"]
      }
    }
  }
}
